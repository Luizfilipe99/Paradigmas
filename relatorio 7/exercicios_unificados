// PROGRAMA PRINCIPAL
// ==========================================

public class Program
{
    public static void Main(string[] args)
    {
        Console.WriteLine("--- EXERCÍCIO 1: COMBATENTES ---");
        CombatenteAliado c1 = new CombatenteAliado("Faramir", "Humano", "Capitão");
        c1.ApresentarUnidade();

        Console.WriteLine("\n--- EXERCÍCIO 2: POKÉMON (POLIMORFISMO) ---");
        List<Pokemon> pokedex = new List<Pokemon>
        {
            new TipoFogo("Charizard"),
            new TipoAgua("Blastoise")
        };
        // todo: POLIMORFISMO EM AÇÃO
        foreach (var p in pokedex) { p.ExecutarMovimento(); }

        Console.WriteLine("\n--- EXERCÍCIO 3: FRIEREN (ASSOCIAÇÕES) ---");
        List<string> itensExternos = new List<string> { "Saco de Dormir", "Lampião" };
        Maga frieren = new Maga("Frieren", itensExternos);
        frieren.Bau.GuardarItem(new ReliquiaMagica { NomeItem = "Grimório de Flores" });

        Console.WriteLine("\n--- EXERCÍCIO 4: HORROR CÓSMICO (ABSTRAÇÃO) ---");
        List<AbominacaoCosmica> horrores = new List<AbominacaoCosmica>
        {
            new Shoggoth("Shoggoth Incipiente"),
            new CacadorAlado("Caçador das Estrelas")
        };
        foreach (var h in horrores) { h.Manifestar(); }
    }
}