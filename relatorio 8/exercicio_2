class Musico
  attr_reader :nome, :instrumento

  def initialize(nome, instrumento)
    @nome = nome
    @instrumento = instrumento
  end

  # Abstração: Força as classes filhas a implementarem
  def tocar_partitura(obra)
    raise NotImplementedError, "#{self.class} deve implementar tocar_partitura"
  end
end

class Pianista < Musico
  def initialize(nome)
    super(nome, "Piano")
  end

  # Herança e Sobrescrita
  def tocar_partitura(obra)
    puts "#{@nome} começa a dedilhar intensamente as teclas tocando '#{obra}'!"
  end
end

class Violinista < Musico
  def initialize(nome)
    super(nome, "Violino")
  end

  # Herança e Sobrescrita
  def tocar_partitura(obra)
    puts "#{@nome} desliza o arco com emoção tocando '#{obra}'!"
  end
end

class Maestro
  attr_reader :musicos

  def initialize
    @musicos = []
  end

  def adicionar_musico(musico)
    @musicos << musico
  end

  def iniciar_concerto(obra)
    puts "\n--- Iniciando Concerto: #{obra} ---"
    # Uso do .each para percorrer a lista
    @musicos.each do |m|
      m.tocar_partitura(obra)
    end
  end

  def ajustar_postura(estado)
    puts "\n--- Ajuste de Postura ---"
    # Uso do .map para gerar um novo Array de Strings
    status = @musicos.map do |m|
      "#{m.nome} está em ritmo #{estado} com seu #{m.instrumento}!"
    end
    
    status.each { |mensagem| puts mensagem }
  end
end

# --- MAIN ---
kosei = Pianista.new("Kosei Arima")
kaori = Violinista.new("Kaori Miyazono")

maestro = Maestro.new
maestro.adicionar_musico(kosei)
maestro.adicionar_musico(kaori)

obra = "Introdução e Rondo Capriccioso"

maestro.iniciar_concerto(obra)
maestro.ajustar_postura("Allegro")