class BebidaAfterlife
  # Utilizando o método visto em aula para o getter do nome
  attr_reader :nome

  def initialize(nome, custo_base)
    @nome = nome
    # Convenção de underscore para atributos que requerem controle manual
    @_custo_base = custo_base
  end

  # Getter manual
  def custo_base
    @_custo_base
  end

  # Setter manual com validação
  def custo_base=(novo_valor)
    if novo_valor.is_a?(Numeric) && novo_valor > 0
      @_custo_base = novo_valor
    else
      puts "Erro: O custo base deve ser maior que zero."
    end
  end

  # Polimorfismo: Comportamento base
  def preco_total
    custo_base
  end

  # Método de representação
  def to_string
    "Bebida: #{@nome} | Valor Final: $#{preco_total}"
  end
end

class DrinkIconico < BebidaAfterlife
  attr_reader :nivel_notoriedade

  def initialize(nome, custo_base, nivel_notoriedade)
    # Chama o construtor da classe pai
    super(nome, custo_base)
    @nivel_notoriedade = nivel_notoriedade
  end

  # Sobrescrita (Override) do método base
  def preco_total
    custo_base + (@nivel_notoriedade * 8)
  end

  def to_string
    "Bebida: #{@nome} (Drink Icônico) | Valor Final: $#{preco_total}"
  end
end

# --- MAIN ---
b1 = BebidaAfterlife.new("Cerveja Sintética", 15)
b2 = DrinkIconico.new("Johnny Silverhand", 50, 10)
b3 = DrinkIconico.new("David Martinez", 40, 8)

# Testando o setter com validação
b1.custo_base = 20
b1.custo_base = -5 # Vai disparar a mensagem de erro

bebidas = [b1, b2, b3]

puts "\n--- Pedidos no AfterLife ---"
bebidas.each do |bebida|
  puts bebida.to_string
end